<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    background: #faf8f5;
    color: #2b2b2b;
    margin: 0;
    padding: 2rem 1rem;
    line-height: 1.75;
  }
  .view-toggle {
    position: sticky;
    top: 0.5rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    z-index: 10;
  }
  .view-toggle button {
    font: inherit;
    font-size: 0.85rem;
    padding: 0.3em 1em;
    border: 1px solid #c9c2b6;
    border-radius: 999px;
    background: #fffdf9;
    cursor: pointer;
  }
  .view-toggle button.active { background: #2b2b2b; color: #fffdf9; border-color: #2b2b2b; }
  article.book { max-width: 46rem; margin: 0 auto; }
  article.book.mode-both { max-width: 80rem; }
  h1.book-title { font-size: 1.9rem; text-align: center; margin-bottom: 2.5rem; }
  h2 { font-size: 1.5rem; margin-top: 1.2em; }
  h3 { font-size: 1.2rem; margin-top: 1em; }
  h2:first-child, h3:first-child { margin-top: 0; }
  p { margin: 0 0 1em 0; text-align: justify; }
  .translation-error {
    color: #9b2c2c;
    background: #fff5f5;
    padding: 0.5em 0.75em;
    border-left: 3px solid #9b2c2c;
    font-style: italic;
  }
  .pending {
    opacity: 0.55;
    border-left: 3px dashed #c98f2b;
    padding-left: 0.75em;
  }
  .pending::before {
    content: "(chưa dịch) ";
    color: #975a16;
    font-size: 0.8em;
    font-style: italic;
  }
  .block { margin-bottom: 0.25rem; }
  .mode-both .block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 2.5rem;
    align-items: start;
  }
  .mode-both .original { border-right: 1px solid #e5dfd4; padding-right: 2.5rem; margin-right: -1.25rem; }
  .mode-original .translated { display: none; }
  .mode-translated .original { display: none; }
  /* Images and code listings are not translated — shown once, full width. */
  .block-media, .block-code-block {
    margin: 1.25rem 0;
  }
  .block-media img {
    max-width: 100%;
    display: block;
    margin: 0 auto;
  }
  .block-code-block pre {
    background: #2b2b2b;
    color: #e8e6e1;
    padding: 1em 1.25em;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.85em;
    line-height: 1.5;
  }
  .block-code-block code {
    font-family: "SF Mono", Menlo, Consolas, monospace;
  }
  hr.page-break {
    border: none;
    border-top: 1px dashed #d8d2c8;
    margin: 2rem auto;
    width: 40%;
  }
</style>
</head>
<body>
<nav class="view-toggle">
  <button data-mode="mode-both" class="active">Song ngữ</button>
  <button data-mode="mode-original">Bản gốc</button>
  <button data-mode="mode-translated">Bản dịch</button>
</nav>
{{ body | safe }}
<script>
  const article = document.querySelector("article.book");
  document.querySelectorAll(".view-toggle button").forEach((btn) => {
    btn.addEventListener("click", () => {
      article.classList.remove("mode-both", "mode-original", "mode-translated");
      article.classList.add(btn.dataset.mode);
      document.querySelectorAll(".view-toggle button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
    });
  });
</script>
</body>
</html>
